[Unit]
Description=PGV Earthquake Prediction Flask App
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/datahack2026
Environment="PATH=/home/ec2-user/.local/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/usr/bin/python3 /home/ec2-user/datahack2026/app.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
